<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>İcra Analizi - Ollama</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
      <a class="navbar-brand" href="/">Form Recognizer</a>
      <div class="navbar-nav ms-auto">
        <a class="nav-link" href="/">Analiz</a>
        <a class="nav-link active" href="/icra">İcra Analizi</a>
        <a class="nav-link" href="/admin">Admin</a>
      </div>
    </div>
  </nav>

  <div class="container mt-4">
    <div class="row">
      <div class="col-lg-4">
        <div class="card shadow mb-4">
          <div class="card-header bg-success text-white">
            <h5 class="mb-0">Veri Yükle (XML / CSV)</h5>
          </div>
          <div class="card-body">
            <form id="icraForm">
              <div class="mb-3">
                <label class="form-label">XML veya CSV Dosyaları</label>
                <div class="upload-zone p-3 border rounded text-center" id="dropZone">
                  <p class="mb-1 text-muted small">Dosyaları buraya bırakın</p>
                  <input type="file" id="fileInput" class="form-control form-control-sm" accept=".xml,.csv,.xlsx" multiple>
                </div>
              </div>

              <div id="fileList" class="mb-3 d-none">
                <small class="text-muted"><span id="fileCount">0</span> dosya seçildi</small>
              </div>

              <div class="d-grid">
                <button type="submit" class="btn btn-success" id="processBtn" disabled>
                  Analiz Et ve Excel Oluştur
                </button>
              </div>
            </form>
          </div>
        </div>

        <div class="card shadow">
          <div class="card-header">
            <h5 class="mb-0">Analiz Bilgisi</h5>
          </div>
          <div class="card-body">
            <p class="small text-muted">
              Yüklenen XML/CSV dosyalarındaki içerikler <strong>Ollama</strong> üzerinden analiz edilir. 
              Ödeme durumunun "Sırada" olup olmadığı tespit edilir ve tüm tutarlar için ayrı satırlar oluşturularak 
              <code>ornek.xlsx</code> formatında yeni bir Excel dosyası hazırlanır.
            </p>
          </div>
        </div>
      </div>

      <div class="col-lg-8">
        <div id="statusCard" class="card shadow mb-4 d-none">
          <div class="card-body">
            <div id="loadingInfo" class="text-center py-3">
              <div class="spinner-border text-success mb-2" role="status"></div>
              <p class="mb-0" id="statusText">İşleniyor...</p>
              <div class="progress mt-3" style="height: 10px;">
                <div id="progressBar" class="progress-bar progress-bar-striped progress-bar-animated bg-success" style="width: 0%"></div>
              </div>
            </div>
            <div id="resultInfo" class="d-none text-center py-3">
              <div class="alert alert-success">
                <h5 class="alert-heading">İşlem Tamamlandı!</h5>
                <p id="resultSummary"></p>
                <hr>
                <div class="d-flex flex-wrap justify-content-center gap-2">
                  <a id="downloadBtn" href="#" class="btn btn-primary">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-file-earmark-excel me-1" viewBox="0 0 16 16"><path d="M5.884 6.68a.5.5 0 1 0-.768.64L7.349 10l-2.233 2.68a.5.5 0 0 0 .768.64L8 10.781l2.116 2.54a.5.5 0 0 0 .768-.641L8.651 10l2.233-2.68a.5.5 0 0 0-.768-.64L8 9.219l-2.116-2.54z"/><path d="M14 14V4.5L9.5 0H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2zM9.5 3A1.5 1.5 0 0 0 11 4.5h2V14a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1h5.5v2z"/></svg>
                    Excel İndir
                  </a>
                  <a id="downloadCsvBtn" href="#" class="btn btn-secondary">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-file-earmark-text me-1" viewBox="0 0 16 16"><path d="M5.5 7a.5.5 0 0 0 0 1h5a.5.5 0 0 0 0-1zM5 9.5a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1-.5-.5m0 2a.5.5 0 0 1 .5-.5h2a.5.5 0 0 1 0 1h-2a.5.5 0 0 1-.5-.5"/><path d="M9.5 0H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2V4.5zm0 1v3.5A1.5 1.5 0 0 0 11 6h3.5V14a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1h5.5z"/></svg>
                    CSV İndir (Toplu)
                  </a>
                </div>
                <div id="xmlDownloadLinks" class="mt-3 text-start small">
                  <strong>XML Dosyaları:</strong>
                  <ul id="xmlList" class="list-unstyled mb-0"></ul>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div id="logCard" class="card shadow d-none">
          <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <h6 class="mb-0">İşlem Günlüğü</h6>
            <button class="btn btn-sm btn-outline-light" id="clearLogs">Temizle</button>
          </div>
          <div class="card-body p-0">
            <div id="logOutput" class="bg-dark text-success p-3" style="height: 400px; overflow-y: auto; font-family: monospace; font-size: 13px;"></div>
          </div>
        </div>

        <div id="emptyState" class="text-center py-5 text-muted bg-light border rounded shadow-sm">
          <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="currentColor" class="bi bi-gear-wide-connected mb-3" viewBox="0 0 16 16">
            <path d="M7.068.727c.243-.97 1.62-.97 1.864 0l.071.286a.96.96 0 0 0 1.622.434l.205-.211c.695-.719 1.888-.03 1.613.931l-.08.284a.96.96 0 0 0 1.187 1.187l.283-.081c.96-.275 1.65.918.931 1.613l-.211.205a.96.96 0 0 0 .433 1.622l.286.071c.97.243.97 1.62 0 1.864l-.286.071a.96.96 0 0 0-.434 1.622l.211.205c.719.695.03 1.888-.931 1.613l-.284-.08a.96.96 0 0 0-1.187 1.187l.081.283c.275.96-.918 1.65-1.613.931l-.205-.211a.96.96 0 0 0-1.622.433l-.071.286c-.243.97-1.62.97-1.864 0l-.071-.286a.96.96 0 0 0-1.622-.434l-.205.211c-.695.719-1.888.03-1.613-.931l.08-.284a.96.96 0 0 0-1.186-1.187l-.284.081c-.96.275-1.65-.918-.931-1.613l.211-.205a.96.96 0 0 0-.433-1.622l-.286-.071c-.97-.243-.97-1.62 0-1.864l.286-.071a.96.96 0 0 0 .434-1.622l-.211-.205c-.719-.695-.03-1.888.931-1.613l.284.08a.96.96 0 0 0 1.187-1.187l-.081-.283c-.275-.96.918-1.65 1.613-.931l.205.211a.96.96 0 0 0 1.622-.433zM12.983 8a4.983 4.983 0 1 0-9.967 0 4.983 4.983 0 0 0 9.967 0"/>
          </svg>
          <p>Dosya yükleyerek işlemi başlatın</p>
          <small>Seçilen XML/CSV içindeki her bir kayıt için Ollama analizi yapılır</small>
        </div>
      </div>
    </div>
  </div>

  <script src="/js/icra.js"></script>
</body>
</html>
