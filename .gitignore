# ==========================================
# DEFAULT: IGNORE EVERYTHING
# ==========================================
/*
!.gitignore
!README.md
!LICENSE

# ==========================================
# ALLOWED PROJECT DIRECTORIES
# ==========================================
!/azure-form-recognizer-app/
!/b2b-leads-turkey/
!/designflow-studio/

# Allow specific Desktop projects if needed
# !/Desktop/
# !/Desktop/Digitaliulm/
# !/Desktop/open-design/

# ==========================================
# GIT & BACKUP FILES
# ==========================================
*.orig
*.backup

# ==========================================
# OS SPECIFIC
# ==========================================
.DS_Store
.DS_Store?
._*
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db

# ==========================================
# IDE & EDITOR
# ==========================================
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
.idea/
*.swp
*.swo
*~

# ==========================================
# ENVIRONMENT & SECRETS
# ==========================================
.env
.env.local
.env.*.local
*.key
.env.production
.env.development

# ==========================================
# DEPENDENCIES
# ==========================================
node_modules/
__pycache__/
*.egg-info/
dist/
build/

# ==========================================
# LOCAL & TEMP
# ==========================================
.netlify
.cache
.next
.nuxt
dist
.vuepress/dist

# ==========================================
# LOGS
# ==========================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
